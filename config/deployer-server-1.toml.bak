#Allows create to interact with blocks that provide block capability, even though they have no block entity
blockCapabilityFix = true
#Determines how many times a factory panel can be updated in the same tick
# Default: 16
# Range: > 0
factoryPanelMaxCyclesPerTick = 16
#Uses a different algorithm to perform re-packaging behaviour, reducing it from O(n⁴) to O(n). If other mods collide or modify the behaviour, disable it
fastRepackageAlgorithm = false
