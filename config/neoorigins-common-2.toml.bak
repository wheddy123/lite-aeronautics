#Log per-namespace power counts after each data reload.
#Useful for addon and datapack authors debugging load issues.
debug_power_loading = false

#Enable or disable built-in origins.
#Set to false to remove an origin from the selection screen.
#Datapack and originpack origins are not affected by these toggles.
[origins]
	human = true
	merling = true
	avian = true
	blazeling = true
	elytrian = true
	enderian = true
	arachnid = true
	shulk = true
	phantom = true
	feline = true
	golem = true
	caveborn = true
	sylvan = true
	draconic = true
	revenant = true
	tiny = true
	abyssal = true
	voidwalker = true
	stoneguard = true
	verdant = true
	umbral = true
	inchling = true
	sporeling = true
	frostborn = true
	strider = true
	siren = true
	piglin = true
	hiveling = true
	cinderborn = true
	sculkborn = true
	enderite = true
	necromancer = true
	gorgon = true
	automaton = true
	kraken = true
	warden = true
	dwarf = true
	breeze = true
	vampire = true
	air_mage = true
	darkness_mage = true
	earth_mage = true
	fire_mage = true
	gravity_mage = true
	water_mage = true
	monster_tamer = true

#Enable or disable built-in classes.
#Set to false to remove a class from the selection screen.
#If all classes are disabled, the class selection screen is skipped entirely.
[classes]
	class_warrior = true
	class_archer = true
	class_miner = true
	class_beastmaster = true
	class_explorer = true
	class_sentinel = true
	class_herbalist = true
	class_scout = true
	class_berserker = true
	class_titan = true
	class_rogue = true
	class_lumberjack = true
	class_blacksmith = true
	class_cook = true
	class_merchant = true
	class_cleric = true
	class_nitwit = true

#Per-power dimension restrictions.
#Powers listed here will be disabled when the player is in the specified dimension(s).
#Format: "<power_id> = <dimension1>, <dimension2>, ..."
#Example: "neoorigins:elytrian_flight = minecraft:the_nether, minecraft:the_end"
[dimension_restrictions]
	rules = []

#Per-power parameter overrides.
#Edit any value below to override it. Only values changed from their default are applied.
#20 ticks = 1 second. Overrides take effect on /reload or restart.
[power_overrides]

	[power_overrides.abyssal_thorns_aura]
		# Default: 0.3
		# Range: 0.0 ~ 10.0
		return_ratio = 0.3

	[power_overrides.abyssal_regen_in_water]
		# Default: 2.0
		# Range: 0.0 ~ 100.0
		amount_per_second = 2.0

	[power_overrides.abyssal_daylight_damage]
		# Default: 1.5
		# Range: 0.0 ~ 100.0
		damage_per_second = 1.5
		ignite = false

	[power_overrides.abyssal_land_speed_penalty]
		# Default: -0.1
		# Range: -1.0 ~ 1.0
		amount = -0.1

	[power_overrides.abyssal_summon_guardian]
		# Default: 2
		# Range: 1 ~ 100
		max_count = 2
		# Default: 400
		# Range: 0 ~ 72000
		cooldown_ticks = 400
		# Default: 5
		# Range: 0 ~ 100
		hunger_cost = 5
		# Default: 18000
		# Range: 0 ~ 1000000
		despawn_ticks = 18000
		# Default: 1.0
		# Range: 0.0 ~ 100.0
		death_damage = 1.0

	[power_overrides.automaton_iron_frame]
